/*
 * Opsero Electronic Design Inc.
 *
 * Port config for designs using all 4 ports of the Ethernet FMC Max,
 * each driven by a PS GEM through EMIO GMII and a PL PCS/PMA (SGMII).
 *
 * All four DP83867 PHYs of the Ethernet FMC Max share a single MDIO bus
 * which is mastered by GEM0 in these designs. The PHYs of ports 1-3 are
 * cross-referenced by gem1-3 via phy-handle.
 *
 * The PL PCS/PMA cores are NOT described here: this kernel's macb driver
 * has no external-PCS support. They sit on GEM0's MDIO bus at address
 * 8+port and power up ISOLATED (control reg 0, bit 10), which cuts the GMII
 * datapath until cleared. The pcs-unisolate boot service clears that bit so
 * traffic flows. Once the kernel gains an "xlnx,pcs" PCS driver, describe the
 * cores here (pcs-handle) and drop that service. See docs/source/advanced.md.
 */

&gem0 {
    local-mac-address = [00 0a 35 00 01 22];
    phy-handle = <&extphy0>;
    phy-mode = "gmii";
    status = "okay";
    xlnx,has-mdio = <0x1>;
    psu_ethernet_0_mdio: mdio {
        #address-cells = <1>;
        #size-cells = <0>;
        extphy0: phy@1 {
            device_type = "ethernet-phy";
            reg = <1>;
            ti,fifo-depth = <0x1>;
            enet-phy-lane-swap;
        };
        extphy1: phy@3 {
            device_type = "ethernet-phy";
            reg = <3>;
            ti,fifo-depth = <0x1>;
            enet-phy-lane-swap;
        };
        extphy2: phy@12 {
            device_type = "ethernet-phy";
            reg = <12>;
            ti,fifo-depth = <0x1>;
            enet-phy-lane-swap;
        };
        extphy3: phy@15 {
            device_type = "ethernet-phy";
            reg = <15>;
            ti,fifo-depth = <0x1>;
            enet-phy-lane-swap;
        };
    };
};

&gem1 {
    local-mac-address = [00 0a 35 00 01 23];
    phy-handle = <&extphy1>;
    phy-mode = "gmii";
    status = "okay";
};

&gem2 {
    local-mac-address = [00 0a 35 00 01 24];
    phy-handle = <&extphy2>;
    phy-mode = "gmii";
    status = "okay";
};

&gem3 {
    local-mac-address = [00 0a 35 00 01 25];
    phy-handle = <&extphy3>;
    phy-mode = "gmii";
    status = "okay";
};
